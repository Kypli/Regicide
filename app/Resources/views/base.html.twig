<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8"/>
    <title>{% block title %}Régicide{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0-beta.3/css/bootstrap.min.css"
              integrity="sha384-Zug+QiDoJOrZ5t4lssLdxGhVrurbmBWopoEl+M6BdEfwnCJZtKxi1KgxUyJq13dy" crossorigin="anonymous">
        <link href="{{ asset('css/global.css') }}" rel="stylesheet">
    {% endblock %}
    <link rel="icon" type="image/x-icon" href="{{ asset('assets/image/interface/favicon.ico') }}"/>
</head>
<body>
{% block header %}
{% endblock %}
{% block navbar %}
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <a class="navbar-brand" href="#">Navbar</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item active">
                    <a class="nav-link" href="#">Home <span class="sr-only">(current)</span></a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Compte</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Règles</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Forum</a>
                </li>
            </ul>
        </div>
    </nav>
{% endblock %}
<div class="col-md-12 row province">Nom de la province</div>
<div class="row">
    <div class="infosrapides col-md-4">Infos rapides
        <div class="info_rapide_image">
            <table class="info_rapide_img_icone" class="info_rapide_img_icone_class">
                <tbody>
                <tr class="info_rapide_img_icone_image">
                    <td>
                        <img alt="info_rapide_pv" src="{{ asset('assets/image/interface/pv_rapport.png') }}" title="Points de vie">
                    </td>
                    <td>
                        <img alt="info_rapide_vigueur" src="{{ asset('assets/image/interface/vig_rapport.png') }}" title="Vigueur">
                    </td>
                    <td>
                        <img alt="info_rapide_satiete" src="{{ asset('assets/image/interface/sat_rapport.png') }}" title="Satiété">
                    </td>
                    <td>
                        <a href="#" title="Courrier"><img alt="info_rapide_courriel" src="{{ asset('assets/image/interface/courriel.png') }}"></a>
                    </td>
                </tr>
                <tr class="info_rapide_img_icone_chiffre">
                    <td>
                        6
                    </td>
                    <td>
                        31
                    </td>
                    <td>
                        38
                    </td>
                    <td>
                        <a href="#">0</a>
                    </td>
                </tr>
                <tr>
                    <td class="info_rapide_img_icone_temps_1">
                        <img alt="info_rapide_temps" src="{{ asset('assets/image/interface/tps_rapport.png') }}" title="Temps restant">
                    </td>
                    <td class="info_rapide_img_icone_temps_2" colspan="3">
                        38h 18mn 50s
                    </td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="carte col-md-4">
        Carte
        {% block content %}{% endblock %}
    </div>
    <div class="tchat col-md-4">
        Tchat
    </div>
</div>
<hr>

<div class="row">
    <div class="infos col-md-6">Liste d'ordres
        <div class="perso">
            <p>Personnage</p>
            <div class="row">
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="infos">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="bien-être">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="production">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="inventaire">
                    </a>
                </div>
            </div>
        </div>
        <div class="field">
            <p>Terrain</p>
            <div class="row">
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="infos">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="production">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="surface">
                    </a>
                </div>
            </div>
        </div>
        <div class="construction">
            <p>Construction</p>
            <div class="row">
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="terrain">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="batiment">
                    </a>
                </div>
            </div>
        </div>
        <div class="inventory">
            <p>Inventaire</p>
            <div class="row">
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="nourriture">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="bois">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="minéraux">
                    </a>
                </div>
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="végétaux">
                    </a>
                </div>
            </div>
        </div>
        <div class="objects">
            <p>Objets</p>
            <div class="row">
                <div class="col-md-2">
                    <a href="#" class="thumbnail">
                        <img class="img-thumbnail img-responsive" src="..." alt="infos">
                    </a>
                </div>

            </div>
        </div>
    </div>
    <div class="carte col-md-6">
        Ordre en cours
    </div>
</div>
{% block body %}{% endblock %}

<script src="{{ asset('js/main.js') }}"></script>
<script src="https://code.jquery.com/jquery-3.3.1.js"
        integrity="sha256-2Kok7MbOyxpgUVvAk/HJ2jigOSYS2auK4Pfzbm7uH60="
        crossorigin="anonymous"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
